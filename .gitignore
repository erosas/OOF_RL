# Capture files — can be large, machine-specific
captures/

# Database — user data, not source
*.db

# Compiled binaries
*.exe
*.exe~

# API documentation PDFs
*.pdf

# Test / coverage artifacts (root-anchored: a bare "core" would also ignore
# new files under internal/core/)
coverage.out
coverage.html
/core
/corecov
dist/

# Release-build staging for go:embed — populated by package-release.ps1,
# only the .gitkeep placeholder is tracked
bundled/plugins/*
!bundled/plugins/.gitkeep

# Local config — may contain API keys and machine-specific paths
config.toml

# IDE
.idea/

# Runtime log (written by the app when the console is suppressed)
*.log

# Claude Code project memory
.claude/
